import random

transactions = []

types = {
    "balance":1,
    "statement":2,
    "withdrawal":3,
    "transfer":5
}

for i in range(30):
    ttype = random.choice(list(types.keys()))
    arrival = random.randint(0,50)
    burst = types[ttype]

    transactions.append({
        "id": i+1,
        "type": ttype,
        "arrival": arrival,
        "burst": burst
    })

print("\nGenerated Transactions")
print("ID\tType\t\tArrival\tBurst")
for t in transactions:
    print(f"{t['id']}\t{t['type']}\t\t{t['arrival']}\t{t['burst']}")

time = 0
completed = []
ready = []
response_times = []

while transactions or ready:

    for t in transactions[:]:
        if t["arrival"] <= time:
            ready.append(t)
            transactions.remove(t)

    if ready:
        ready.sort(key=lambda x: x["burst"])
        job = ready.pop(0)

        start = time
        response = start - job["arrival"]

        time += job["burst"]

        completed.append(job["id"])
        response_times.append(response)


    else:
        time += 1

avg_response = sum(response_times)/len(response_times)
throughput = len(response_times)/time

#print("\nExecution Order:", completed)
print("Average Response Time:", avg_response)
print("Throughput:", throughput)
