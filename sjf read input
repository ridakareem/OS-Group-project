burst_times = {
    "balance": 1,
    "statement": 2,
    "withdrawal": 3,
    "transfer": 5
}

n = int(input("Enter number of transactions: "))

transactions = []

for i in range(n):
    print(f"\nTransaction {i+1}")

    arrival = int(input("Arrival time: "))
    ttype = input("Type (balance/statement/withdrawal/transfer): ").lower()

    burst = burst_times[ttype]

    transactions.append({
        "id": i+1,
        "arrival": arrival,
        "burst": burst
    })

time = 0
completed = []
ready = []

response_times = []

while transactions or ready:

    for t in transactions[:]:
        if t["arrival"] <= time:
            ready.append(t)
            transactions.remove(t)

    if ready:

        ready.sort(key=lambda x: x["burst"])
        job = ready.pop(0)

        start = time
        response = start - job["arrival"]

        time += job["burst"]

        completed.append(job["id"])
        response_times.append(response)

        print(f"Transaction {job['id']} executed from {start} to {time}")

    else:
        time += 1

avg_response = sum(response_times) / len(response_times)
throughput = len(response_times) / time

print("\nExecution Order:", completed)
print("Average Response Time:", avg_response)
print("Throughput:", throughput)
